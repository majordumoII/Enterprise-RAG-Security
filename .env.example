# GCP Project (query-time embeddings only — must match Project 1's ingestion model/dims)
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json

# Embedding (Vertex AI) — same model Project 1 used to embed stored chunks
EMBEDDING_MODEL=text-embedding-005
EMBEDDING_DIMENSIONS=768
EMBEDDING_LOCATION=us-east1

# Cloud SQL pgvector — point at the SAME instance/table Project 1 populated
# Local dev (via Cloud SQL Auth Proxy on localhost):
PG_CONNECTION_STRING=postgresql://pipeline:changeme@localhost:5432/docpipeline
VECTOR_TABLE=document_chunks

# Cloud SQL pgvector — Cloud Run / production deployments
# When DB_INSTANCE_CONNECTION_NAME is set, the vector store connects via the
# Cloud SQL Python Connector (IAM auth) instead of PG_CONNECTION_STRING.
DB_INSTANCE_CONNECTION_NAME=your-project:region:instance-name
DB_NAME=docpipeline
DB_USER=pipeline
DB_PASSWORD=changeme

# Generation LLM — pluggable: "openai" or "deepseek"
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-4.1-mini

# DeepSeek (OpenAI-compatible API — used only when LLM_PROVIDER=deepseek)
DEEPSEEK_API_KEY=your-deepseek-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# NeMo Guardrails
GUARDRAILS_CONFIG_PATH=config/rails

# Retrieval
TOP_K=5
